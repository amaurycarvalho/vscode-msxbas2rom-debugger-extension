{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Clean",
      "type": "shell",
      "command": "npm run clean",
      "group": {
        "kind": "none"
      }
    },
    {
      "label": "Build",
      "type": "shell",
      "command": "npm run package",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        {
          "owner": "vsce",
          "pattern": {
            "regexp": "^\\s+ERROR\\s+(.*)$",
            "message": 1
          }
        }
      ]
    },
    {
      "label": "Package scanning check",
      "type": "shell",
      "command": "npm run scan",
      "group": {
        "kind": "none"
      },
      "problemMatcher": [
        {
          "owner": "vsce",
          "pattern": {
            "regexp": "^\\s+ERROR\\s+(.*)$",
            "message": 1
          }
        }
      ]
    },
    {
      "label": "Test",
      "type": "shell",
      "command": "npm test",
      "group": {
        "kind": "test",
        "isDefault": true
      }
    }
  ]
}
